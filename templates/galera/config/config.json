{
    "command": "/usr/local/bin/detect_gcomm_and_start.sh",
    "config_files": [
        {
            "source": "/var/lib/pod-config-data/.my.cnf",
            "dest": "/etc/my.cnf.d/.my.cnf",
            "owner": "mysql",
            "perm": "0600"
        },
        {
            "source": "/var/lib/pod-config-data/galera.cnf",
            "dest": "/etc/my.cnf.d/galera.cnf",
            "owner": "root",
            "perm": "0644"
        },
        {
            "source": "/var/lib/pod-config-data/galera_custom.cnf",
            "dest": "/etc/my.cnf.d/galera_custom.cnf",
            "owner": "root",
            "perm": "0644",
            "optional": true
        },
        {
            "source": "/var/lib/pod-config-data/galera_sst_mariabackup.cnf",
            "dest": "/etc/my.cnf.d/galera_mariabackup.cnf",
            "owner": "root",
            "perm": "0644",
            "optional": true
        },
        {
            "source": "/var/lib/operator-scripts",
            "dest": "/usr/local/bin",
            "owner": "root",
            "perm": "0755",
            "merge": "true"
        }
    ],
    "permissions": [
        {
            "path": "/var/lib/mysql",
            "owner": "mysql:mysql",
            "recurse": "true"
        }
    ]
}
